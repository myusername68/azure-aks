# Azure AKS Cluster Configuration
# Copy this file to terraform.tfvars and adjust values as needed.

resource_group_name = "azure-aks-rg"
location            = "westeurope"
cluster_name        = "azure-aks"
kubernetes_version  = "1.34"

# System node pool (always-on)
system_node_vm_size = "Standard_D2s_v3"
system_node_count   = 1

# User node pool (spot instances, autoscaling)
user_node_vm_size   = "Standard_D2s_v3"
user_node_min_count = 0
user_node_max_count = 2

# ACR name (globally unique, alphanumeric only)
# Leave commented out to auto-generate from subscription ID
# acr_name = "myuniqueacrname"

tags = {
  project     = "azure-aks"
  environment = "dev"
  managed_by  = "terraform"
}
